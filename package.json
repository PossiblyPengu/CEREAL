{
  "name": "cereal-launcher-vite",
  "private": true,
  "version": "0.0.2",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:native": "dotnet build electron/native/MediaInfoTool/MediaInfoTool.csproj -c Release --nologo -v quiet",
    "build": "tsc -b && vite build",
    "package": "npm run build && electron-builder --win --dir",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "start": "electron dist-electron/main.js",
    "preview": "vite preview",
    "build:icons": "node scripts/build-icons.mjs",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "patch-package": "^8.0.1",
    "to-ico": "^1.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
